{
  "name": "ibm-infrastructure-explorer",
  "version": "1.0.0",
  "description": "IBM Cloud Infrastructure Explorer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch --env-file=.env server/src/index.ts\"",
    "build": "vite build && tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --project frontend",
    "test:backend": "vitest run --project backend",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.2",
    "@carbon/charts-react": "^1.27.2",
    "@carbon/icons-react": "^11.55.0",
    "@carbon/react": "^1.75.0",
    "@react-spring/web": "^9.7.5",
    "@xyflow/react": "^12.10.0",
    "axios": "^1.7.9",
    "compression": "^1.7.5",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dagre": "^0.8.5",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "helmet": "^8.0.0",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.1",
    "react-simple-maps": "^3.0.0",
    "react-window": "^1.8.11",
    "recharts": "^2.15.4",
    "sass": "^1.83.4",
    "topojson-client": "^3.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/dagre": "^0.7.53",
    "@types/express": "^5.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/react-simple-maps": "^3.0.6",
    "@types/react-window": "^1.8.8",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "jsdom": "^27.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.21.0",
    "vite": "^5.4.14",
    "vitest": "^2.1.8"
  }
}
