{
  "name": "ibm-infrastructure-explorer",
  "version": "1.0.0",
  "description": "IBM Cloud Infrastructure Explorer",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"tsx watch --env-file=.env server/src/index.ts\"",
    "build": "vite build && tsc -p server/tsconfig.json",
    "start": "node server/dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:frontend": "vitest run --project frontend",
    "test:backend": "vitest run --project backend",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug"
  },
  "dependencies": {
    "@carbon/charts": "^1.27.2",
    "@carbon/charts-react": "^1.27.2",
    "@carbon/icons-react": "^11.55.0",
    "@carbon/react": "^1.75.0",
    "@react-spring/web": "^10.0.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/jspdf": "^1.3.3",
    "@xyflow/react": "^12.10.0",
    "axios": "^1.7.9",
    "compression": "^1.7.5",
    "d3-hierarchy": "^3.1.2",
    "d3-interpolate": "^3.0.1",
    "d3-scale": "^4.0.2",
    "d3-shape": "^3.2.0",
    "dagre": "^0.8.5",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "helmet": "^8.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "react-simple-maps": "^3.0.0",
    "recharts": "^2.15.4",
    "sass": "^1.83.4",
    "topojson-client": "^3.1.0",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.7.5",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/dagre": "^0.7.53",
    "@types/express": "^5.0.0",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-simple-maps": "^3.0.6",
    "@types/topojson-client": "^3.1.5",
    "@vitejs/plugin-react": "^5.2.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "jsdom": "^27.4.0",
    "tsx": "^4.19.2",
    "typescript": "~5.9",
    "typescript-eslint": "^8.21.0",
    "vite": "^7.3.1",
    "vitest": "^4.1.0"
  }
}
